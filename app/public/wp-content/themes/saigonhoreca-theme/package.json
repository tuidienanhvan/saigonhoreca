{
  "name": "saigonhoreca-theme",
  "version": "1.0.0",
  "description": "Saigon Horeca WordPress Theme — bếp công nghiệp & quầy bar. Tailwind v4, per-route bundles, static HTML cache, image-LCP. Forked từ saigonhoreca-theme.",
  "main": "index.php",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/style.css -o ./assets/css/dist/theme.css --watch",
    "dev:home": "tailwindcss -i ./assets/css/entrypoints/style-home.css -o ./assets/css/dist/theme-home.css --watch",
    "build": "npm run build:theme && npm run build:home && npm run build:about && npm run build:contact && npm run build:single && npm run build:product && npm run build:project && npm run build:archive && npm run build:archive-product && npm run build:archive-project",
    "build:theme": "tailwindcss -i ./assets/css/style.css -o ./assets/css/dist/theme.css --minify",
    "build:home": "tailwindcss -i ./assets/css/entrypoints/style-home.css -o ./assets/css/dist/theme-home.css --minify",
    "build:about": "tailwindcss -i ./assets/css/entrypoints/style-about.css -o ./assets/css/dist/theme-about.css --minify",
    "build:contact": "tailwindcss -i ./assets/css/entrypoints/style-contact.css -o ./assets/css/dist/theme-contact.css --minify",
    "build:single": "tailwindcss -i ./assets/css/entrypoints/style-single.css -o ./assets/css/dist/theme-single.css --minify",
    "build:product": "tailwindcss -i ./assets/css/entrypoints/style-product.css -o ./assets/css/dist/theme-product.css --minify",
    "build:project": "tailwindcss -i ./assets/css/entrypoints/style-project.css -o ./assets/css/dist/theme-project.css --minify",
    "build:archive": "tailwindcss -i ./assets/css/entrypoints/style-archive.css -o ./assets/css/dist/theme-archive.css --minify",
    "build:archive-product": "tailwindcss -i ./assets/css/entrypoints/style-archive-product.css -o ./assets/css/dist/theme-archive-product.css --minify",
    "build:archive-project": "tailwindcss -i ./assets/css/entrypoints/style-archive-project.css -o ./assets/css/dist/theme-archive-project.css --minify"
  },
  "keywords": ["wordpress", "theme", "horeca", "tailwindcss"],
  "author": "Saigon Horeca",
  "license": "ISC",
  "dependencies": {
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0"
  }
}
