              "image": {
                "src": "__TEMPLATE_URI__/static-mirror/wp-content/uploads/elementor/thumbs/gmb-2-e1631781552190-1-qhbnq2ivvrtvsf8ygk07yoa3igx0toy1ake7erzfd4.jpg",
                "srcset": null,
