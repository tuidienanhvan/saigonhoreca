      "columns": [
        {
          "col_class": "elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-6c5398a4",
          "col_size": 100,
          "widgets": [
            {
              "type": "text-editor.default",
              "paragraphs": [
                "Roka Fella không chỉ thu hút thực khách bởi ẩm thực và âm nhạc, mà còn bởi không gian sang trọng được chăm chút tỉ mỉ. Và góp phần không nhỏ ấy chính từ Saigon Horeca, đối tác đáng tin cậy của HypeAsia. Saigon Horeca đã tư vấn, thiết kế và lắp đặt hoàn chỉnh trang thiết bị cho Bếp, Quầy Sushi, và Quầy Bar của nhà hàng, hứa hẹn mang đến trải nghiệm ẩm thực thượng hạng trong một không gian đẳng cấp."
              ]
            }
          ]
        }
      ]
    },
    {
      "data_id": "1e7c50ea",
      "css_classes": [
        "elementor-section",
